# ─────────────────────────────────────────────
#  CFMS Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cfms_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT secret (use a long random string — keep this private)
JWT_SECRET=change_this_to_a_long_random_secret_string_12345

# Server port
PORT=3000

# Node environment
NODE_ENV=development
